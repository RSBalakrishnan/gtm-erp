# --- Gmail SMTP Outreach ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=GTM Analytics <your-email@gmail.com>

# --- Google Cloud Platform (Service Account) ---
GCP_PROJECT_ID=your-project-id
GCP_PRIVATE_KEY_ID=your-private-key-id
# Note: Private key contains newlines encoded as \n
GCP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
GCP_CLIENT_EMAIL=your-service-account-email
GCP_CLIENT_ID=your-client-id

# --- Google Sheets ---
SPREADSHEET_ID=your-spreadsheet-id
SERVICE_ACCOUNT_FILE=your-service-account-file.json

# --- Analytica Tracking API ---
ANALYTICA_BASE=http://your-analytica-api-url
TEST_PIXEL_URL=http://your-analytica-api-url/pixel/test-id-123

# --- Scraper API ---
SCRAPER_API_URL=http://your-scraper-api-url

# --- OpenClaw Core & Models ---
BEDROCK_BASE_URL=https://bedrock-mantle.us-east-1.api.aws/v1/
OPENCLAW_BEDROCK_API_KEY=your-bedrock-api-key
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
OPENCLAW_GATEWAY_TOKEN=your-gateway-token

# --- OpenClaw Skills ---
LINKEDIN_SKILL_OWNER_ID=your-linkedin-skill-id
GMAIL_SKILL_OWNER_ID=your-gmail-skill-id
