{
  "meta": {
    "lastTouchedVersion": "2026.3.13",
    "lastTouchedAt": "2026-04-08T03:37:13.998Z"
  },
  "logging": {
    "level": "info",
    "file": "/Users/administrator/Documents/gtm/runner/logs/gtm-v2.log",
    "redactSensitive": "off"
  },
  "browser": {
    "headless": true,
    "noSandbox": true
  },
  "models": {
    "providers": {
      "bedrock-minimax": {
        "baseUrl": "${BEDROCK_BASE_URL}",
        "apiKey": "${OPENCLAW_BEDROCK_API_KEY}",
        "api": "openai-completions",
        "models": [
          {
            "id": "minimax.minimax-m2.5",
            "name": "MiniMax m2.5 (Bedrock)"
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": "bedrock-minimax/minimax.minimax-m2.5",
      "workspace": "/Users/administrator/Documents/gtm/agents/gtm-v2/workspace",
      "compaction": {
        "mode": "safeguard"
      },
      "timeoutSeconds": 180,
      "sandbox": {
        "browser": {
          "enabled": true
        }
      }
    },
    "list": [
      {
        "id": "gtm-v2",
        "name": "GTM Sales Orchestrator V2",
        "workspace": "/Users/administrator/Documents/gtm/agents/gtm-v2",
        "agentDir": "/Users/administrator/Documents/gtm/agents/gtm-v2",
        "model": "bedrock-minimax/minimax.minimax-m2.5",
        "skills": [
          "browser",
          "fetch",
          "fs",
          "linkedin"
        ]
      }
    ]
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "channels": {
    "whatsapp": {
      "enabled": false,
      "dmPolicy": "pairing",
      "groupPolicy": "allowlist",
      "debounceMs": 0,
      "mediaMaxMb": 50
    },
    "telegram": {
      "enabled": false,
      "dmPolicy": "open",
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "groupPolicy": "open",
      "allowFrom": [
        "*"
      ],
      "groupAllowFrom": [
        "*"
      ],
      "streaming": "partial"
    }
  },
  "gateway": {
    "port": 18793,
    "mode": "local",
    "bind": "loopback",
    "controlUi": {
      "allowedOrigins": [
        "http://localhost:18793",
        "http://127.0.0.1:18793"
      ]
    },
    "auth": {
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    }
  },
  "plugins": {
    "entries": {
      "telegram": {
        "enabled": false
      }
    }
  }
}